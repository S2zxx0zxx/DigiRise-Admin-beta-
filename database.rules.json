{
  "rules": {

    "partners": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$code": {
        ".read": "auth != null",
        ".write": "auth != null",
        "goals": {
          "$month": {
            ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 50"
          }
        },
        "referralBonus": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        },
        "referralBonusPaid": {
          ".validate": "newData.isBoolean()"
        }
      }
    },

    "deals": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$partnerCode": {
        ".read": "auth != null",
        ".write": "auth != null",
        "$dealId": {
          ".validate": "newData.hasChildren(['clientName', 'package', 'commission', 'partnerCode']) && newData.child('clientName').isString() && newData.child('package').isString() && newData.child('commission').isNumber() && newData.child('partnerCode').isString()"
        }
      }
    },

    "payouts": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$partnerCode": {
        ".read": "auth != null",
        ".write": "auth != null",
        "$payoutId": {
          ".validate": "newData.hasChildren(['amount', 'status']) && newData.child('amount').isNumber() && newData.child('amount').val() > 0 && newData.child('status').isString()"
        }
      }
    },

    "announcements": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$annId": {
        ".validate": "newData.hasChildren(['title', 'body']) && newData.child('title').isString() && newData.child('body').isString()"
      }
    },

    "activity": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["time"],
      "$actId": {
        ".validate": "newData.hasChildren(['icon', 'text', 'time']) && newData.child('text').isString() && newData.child('time').isNumber()"
      }
    },

    "presence": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$code": {
        ".validate": "newData.hasChildren(['online']) && newData.child('online').isBoolean()"
      }
    },

    "notifications": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$code": {
        ".read": "auth != null",
        ".write": "auth != null",
        "$notifId": {
          ".validate": "newData.hasChildren(['text', 'time']) && newData.child('text').isString() && newData.child('time').isNumber()"
        }
      }
    },

    "settings": {
      ".read": "auth != null",
      ".write": "auth != null",
      "adminPasswordHash": {
        ".validate": "newData.isString() && newData.val().length == 64"
      },
      "whatsappNumber": {
        ".validate": "newData.isString()"
      }
    },

    "seeded": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    "test_wiring": {
      ".read": "auth != null",
      ".write": "auth != null"
    }
  }
}